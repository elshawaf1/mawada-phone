# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin App (apps/admin/mawada-admin/.env.local)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Mobile App (apps/mobile/.env)
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# EXPO_PUBLIC_PAYMOB_PUBLIC_KEY=your-paymob-public-key
# EXPO_PUBLIC_PAYMOB_CARD_INTEGRATION_ID=your-card-integration-id
# EXPO_PUBLIC_PAYMOB_WALLET_INTEGRATION_ID=your-wallet-integration-id
# EXPO_PUBLIC_PAYMOB_VALU_INTEGRATION_ID=your-valu-integration-id

# Edge Functions (set via `supabase secrets set`)
# PAYMOB_SECRET_KEY=your-paymob-secret-key
# PAYMOB_HMAC=your-paymob-hmac
# EXPO_ACCESS_TOKEN=your-expo-access-token
